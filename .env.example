# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # Chave de serviço (backend only)
SUPABASE_ANON_KEY=eyJhbGc...           # Chave pública (usada como fallback)

# ── Auth ─────────────────────────────────────────────────────
# Gere uma string aleatória segura (ex: openssl rand -base64 32)
JWT_SECRET=sua-chave-super-secreta-longa-e-aleatoria

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production

# URL do frontend em produção (para configurar CORS)
# Em dev: http://localhost:5173 (padrão automático, não precisa setar)
FRONTEND_URL=https://seu-dominio.vercel.app

# Porta do backend local (padrão: 3001)
PORT=3001
